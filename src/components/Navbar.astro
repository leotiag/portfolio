---
import { translations } from "../i18n/translations";

const { lang = "en" } = Astro.props;
const t = translations[lang];
---

<nav
id="navbar"
class="w-full h-16 text-white flex items-center justify-between px-6 fixed top-0 z-50 transition-all duration-300"
>

   <!-- Réseaux sociaux -->
   <div class="flex gap-4 text-2xl">

      <a href="https://linkedin.com/in/leonel-tiague-691670107" target="_blank" class="opacity-70 hover:opacity-100">
         <i class='bx bxl-linkedin'></i>
      </a>

      <a href="https://github.com" target="_blank" class="opacity-70 hover:opacity-100">
         <i class='bx bxl-github'></i>
      </a>

      <a href="https://instagram.com" target="_blank" class="opacity-70 hover:opacity-100">
         <i class='bx bxl-instagram'></i>
      </a>

   </div>

   <!-- Bouton menu mobile -->
   <button id="menu-btn" class="md:hidden text-3xl transition">
      ☰
   </button>

   <!-- Navigation desktop (inchangée) -->
   <ul class="hidden md:flex gap-6">

      <li><a href="#home">{t.home}</a></li>
      <li><a href="#about">{t.about}</a></li>
      <li><a href="#technologies">{t.technologies}</a></li>
      <li><a href="#entreprise">{t.entreprise}</a></li>
      <li><a href="#particulier">{t.particulier}</a></li>
      <li><a href="#blog">Blog : "La Tech Simple"</a></li>
      <li><a href="#contact">{t.contact}</a></li>

   </ul>

   <!-- Choix langue desktop -->
   <div class="hidden md:flex gap-2">

      <a
         href="/"
         class="border border-white px-2 py-1 text-sm rounded hover:bg-white hover:text-black"
      >
         EN
      </a>

      <a
         href="/fr"
         class="border border-white px-2 py-1 text-sm rounded hover:bg-white hover:text-black"
      >
         FR
      </a>

   </div>

</nav>

<!-- Menu mobile -->
<div
id="mobile-menu"
class="fixed top-16 left-0 w-full bg-black text-white flex flex-col items-center gap-6 py-6
opacity-0 pointer-events-none transform -translate-y-4
transition-all duration-300 md:hidden z-40"
>

   <a href="#home" class="mobile-link">{t.home}</a>
   <a href="#about" class="mobile-link">{t.about}</a>
   <a href="#technologies" class="mobile-link">{t.technologies}</a>
   <a href="#entreprise" class="mobile-link">{t.entreprise}</a>
   <a href="#particulier" class="mobile-link">{t.particulier}</a>
   <a href="#blog" class="mobile-link">Blog : "La Tech Simple"</a>
   <a href="#contact" class="mobile-link">{t.contact}</a>

   <div class="flex gap-4 mt-4">
      <a href="/" class="border border-white px-3 py-1 rounded">EN</a>
      <a href="/fr" class="border border-white px-3 py-1 rounded">FR</a>
   </div>

</div>

<script>

const btn = document.getElementById("menu-btn");
const menu = document.getElementById("mobile-menu");
const navbar = document.getElementById("navbar");
const links = document.querySelectorAll(".mobile-link");

let open = false;

function openMenu(){

   if(!menu || !btn) return;

   menu.classList.remove("opacity-0","pointer-events-none","-translate-y-4");
   menu.classList.add("opacity-100","translate-y-0");

   btn.textContent = "✕";

   open = true;
}

function closeMenu(){

   if(!menu || !btn) return;

   menu.classList.add("opacity-0","pointer-events-none","-translate-y-4");
   menu.classList.remove("opacity-100","translate-y-0");

   btn.textContent = "☰";

   open = false;
}

btn?.addEventListener("click", () => {

   open ? closeMenu() : openMenu();

});

links.forEach(link => {

   link.addEventListener("click", closeMenu);

});

/* fermeture si clic extérieur (bonne pratique TypeScript) */

document.addEventListener("click", (e) => {

   const target = e.target;

   if(!(target instanceof Node)) return;

   if(open && menu && btn && !menu.contains(target) && !btn.contains(target)){
      closeMenu();
   }

});

/* effet navbar au scroll */

window.addEventListener("scroll", () => {

   if(!navbar) return;

   if(window.scrollY > 50){

      navbar.classList.add(
         "bg-black/70",
         "backdrop-blur-md",
         "shadow-lg"
      );

   } else {

      navbar.classList.remove(
         "bg-black/70",
         "backdrop-blur-md",
         "shadow-lg"
      );

   }

});

</script>