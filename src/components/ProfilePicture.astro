---
import { translations } from "../i18n/translations";
//import tech1 from '../assets/images/tech1.svg';
import smart_home from '../assets/images/smart_home.png';

const { lang = "en" } = Astro.props; // récupère la langue
const t = translations[lang];       // objet des traductions
---

<article class="w-full h-[500px] overflow-hidden flex flex-col items-center justify-center relative md:px-20 xs:px-0">

  <!-- Header avec blockquote bilingue -->
  <header class="text-center absolute top-0 z-10 flex justify-center w-full">
    <blockquote
      class="font-garamond sm:text-[35px] sm:leading-[63px] xxs:text-[30px] xs:text-[16px] max-w-3xl"
    >
      {t.welcome_text}
    </blockquote>
  </header>

  <!-- Image -->
<div class="relative group w-full max-w-lg mx-auto overflow-hidden rounded-xl">

  <img
    src={smart_home.src}
    alt="Portrait of Leonel Tiague"
    class="w-full h-[400px] object-cover object-top shadow-lg transition duration-500 ease-in-out group-hover:scale-105"
  />

  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition duration-300"></div>

  <!-- Source -->
  <div class="absolute bottom-3 right-3 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300 bg-black/70 backdrop-blur-sm text-white text-xs px-3 py-1 rounded-lg">
    Source: wretmanestate.com / l'immobilier 2.0
  </div>

</div>

</article>